{
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://house-rental-demo-production.up.railway.app/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}